  "phq9_guide_r1c1":"Mild",
  "phq9_guide_r1c2":"Use clinical judgment about treatment, based on patient's duration of symptoms and functional impairment",
  "phq9_guide_r2c0":"10-14",
  "phq9_guide_r2c1":"Moderate",
  "phq9_guide_r2c2":"Use clinical judgment about treatment, based on patient's duration of symptoms and functional impairment",
